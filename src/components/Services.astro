---
// Services section - FULL WIDTH cards
const services = [
  {
    title: 'Remodel',
    description: "Transform your kitchen, bathroom, or living space into something extraordinary. We handle everything from design to final walkthrough.",
    icon: '🔨'
  },
  {
    title: 'Renovate', 
    description: "Breathe new life into your entire home. Whether it is updating a vintage charmer or modernizing a dated layout, we make it happen.",
    icon: '🏠'
  },
  {
    title: 'Repair',
    description: "From structural fixes to finishing touches, we solve problems that other contractors walk away from. No job too complex.",
    icon: '🔧'
  }
]
---

<section id="services" class="py-24 md:py-32 bg-warm-white">
  <div class="w-full px-6 md:px-12 lg:px-24">
    <!-- Header -->
    <div class="mb-16">
      <p class="text-gold font-medium mb-4 tracking-wider text-sm uppercase">Services</p>
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold text-charcoal">
        How McCauley<br/>
        Can Help You
      </h2>
    </div>
    
    <!-- Service Cards - FULL WIDTH GRID -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 mb-16">
      {services.map(service => (
        <div class="group bg-cream p-10 lg:p-12 rounded-lg hover:bg-navy transition-all duration-300 cursor-pointer min-h-[320px] flex flex-col">
          <span class="text-5xl mb-6 block">{service.icon}</span>
          <h3 class="text-3xl font-bold mb-4 text-charcoal group-hover:text-white transition-colors">
            {service.title}
          </h3>
          <p class="text-gray-mid group-hover:text-white/80 transition-colors leading-relaxed text-lg flex-1">
            {service.description}
          </p>
          <div class="mt-8 flex items-center gap-2 text-gold font-medium opacity-0 group-hover:opacity-100 transition-opacity">
            Learn More
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Bottom CTA - FULL WIDTH -->
    <div class="bg-cream rounded-lg p-10 lg:p-16">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
        <p class="text-xl md:text-2xl text-gray-mid max-w-2xl leading-relaxed">
          Our craftsmen guide you through every stage of your project with expert 
          knowledge and reliable support.
        </p>
        <a href="#contact" class="btn-primary whitespace-nowrap text-lg">
          Get Started with McCauley
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
