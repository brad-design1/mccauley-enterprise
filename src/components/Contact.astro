---
// Contact section with form
---

<section id="contact" class="section-padding bg-cream">
  <div class="container-custom">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
      <!-- Left: Info -->
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-charcoal mb-6">
          Ready to Build<br/>
          What Matters?
        </h2>
        <p class="text-lg text-gray-mid mb-10 leading-relaxed">
          Let's talk about your project. Whether you have detailed plans or just 
          a vision, we'll help you figure out the best path forward.
        </p>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-navy rounded-lg flex items-center justify-center text-white flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-charcoal">Call Us</p>
              <a href="tel:8155851573" class="text-gray-mid hover:text-gold transition-colors">(815) 585-1573</a>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-navy rounded-lg flex items-center justify-center text-white flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-charcoal">Service Area</p>
              <p class="text-gray-mid">Greater Chicagoland & Southwest Suburbs</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right: Form -->
      <div class="bg-warm-white p-8 md:p-10 rounded-lg">
        <form class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">First Name</label>
              <input type="text" name="firstName" class="w-full px-4 py-3 border border-gray-light rounded-lg focus:ring-2 focus:ring-gold focus:border-transparent outline-none transition-all" placeholder="John" />
            </div>
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">Last Name</label>
              <input type="text" name="lastName" class="w-full px-4 py-3 border border-gray-light rounded-lg focus:ring-2 focus:ring-gold focus:border-transparent outline-none transition-all" placeholder="Smith" />
            </div>
          </div>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">Email</label>
              <input type="email" name="email" class="w-full px-4 py-3 border border-gray-light rounded-lg focus:ring-2 focus:ring-gold focus:border-transparent outline-none transition-all" placeholder="john@example.com" />
            </div>
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">Phone</label>
              <input type="tel" name="phone" class="w-full px-4 py-3 border border-gray-light rounded-lg focus:ring-2 focus:ring-gold focus:border-transparent outline-none transition-all" placeholder="(555) 555-5555" />
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-charcoal mb-2">Project Type</label>
            <select name="projectType" class="w-full px-4 py-3 border border-gray-light rounded-lg focus:ring-2 focus:ring-gold focus:border-transparent outline-none transition-all bg-white">
              <option value="">Select a project type</option>
              <option value="kitchen">Kitchen Remodel</option>
              <option value="bathroom">Bathroom Remodel</option>
              <option value="basement">Basement Finish</option>
              <option value="addition">Addition</option>
              <option value="whole-home">Whole Home Renovation</option>
              <option value="commercial">Commercial Build-Out</option>
              <option value="other">Other</option>
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-charcoal mb-2">Tell Us About Your Project</label>
            <textarea name="message" rows="4" class="w-full px-4 py-3 border border-gray-light rounded-lg focus:ring-2 focus:ring-gold focus:border-transparent outline-none transition-all resize-none" placeholder="Describe your vision, timeline, and any other details..."></textarea>
          </div>
          
          <button type="submit" class="w-full btn-primary justify-center text-lg">
            Request Consultation
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
