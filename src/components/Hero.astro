---
// Hero section - clean, no marquee
const projectPreviews = [
  { thumb: '/images/portfolio-1.png', hero: '/images/accent-architecture.png' },
  { thumb: '/images/portfolio-2.png', hero: '/images/portfolio-5.png' },
  { thumb: '/images/portfolio-3.png', hero: '/images/portfolio-3.png' },
  { thumb: '/images/portfolio-4.png', hero: '/images/accent-craft.png' },
]
---

<section class="relative min-h-screen flex items-end md:items-center overflow-hidden">
  <!-- Background Images -->
  <div class="absolute inset-0 z-0">
    {projectPreviews.map((project, index) => (
      <div 
        class={`hero-bg absolute inset-0 transition-opacity duration-1000 ease-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-bg-index={index}
      >
        <img 
          src={project.hero} 
          alt={`Project ${index + 1}`}
          class="w-full h-full object-cover hero-zoom"
        />
      </div>
    ))}
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/60 via-charcoal/30 to-transparent z-10"></div>
  </div>
  
  <!-- Content -->
  <div class="relative z-20 w-full px-6 md:px-12 lg:px-24 pt-32 md:pt-40 pb-52 md:pb-48 lg:pb-56">
    <div class="max-w-full">
      <h1 class="text-[15vw] md:text-[10vw] lg:text-[8vw] font-bold text-white leading-[0.85] tracking-tight">
        <span class="block reveal-up" style="transition-delay: 0.1s">BUILD</span>
        <span class="block reveal-up" style="transition-delay: 0.2s">WHAT</span>
        <span class="block text-white reveal-up" style="transition-delay: 0.3s">MATTERS</span>
      </h1>
    </div>
  </div>
  
  <!-- Project preview oval (bottom left) -->
  <div class="absolute bottom-6 md:bottom-10 left-6 md:left-12 lg:left-24 z-20 hero-element" style="animation: fadeInUp 0.8s ease-out 1s both">
    <div class="project-preview-pill group cursor-pointer" id="projectPreview">
      <div class="relative w-[120px] h-[70px] md:w-[180px] md:h-[100px] rounded-full overflow-hidden border-2 border-white/40 hover:border-gold hover:scale-105 transition-all duration-300 shadow-2xl">
        <div class="preview-carousel absolute inset-0 flex transition-transform duration-500" id="previewCarousel">
          {projectPreviews.map((project, index) => (
            <img 
              src={project.thumb} 
              alt={`Project ${index + 1}`}
              class="w-full h-full object-cover flex-shrink-0"
            />
          ))}
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll button (bottom right) -->
  <div class="absolute bottom-6 md:bottom-10 right-6 md:right-12 lg:right-24 z-20 hero-element" style="animation: fadeInUp 0.8s ease-out 1.2s both">
    <a href="#services" class="group cursor-pointer">
      <div class="w-14 h-14 md:w-16 md:h-16 rounded-full bg-white flex items-center justify-center shadow-2xl group-hover:scale-110 group-hover:bg-gold transition-all duration-300">
        <span class="text-charcoal text-[10px] md:text-xs font-bold tracking-wider group-hover:text-white transition-colors">SCROLL</span>
      </div>
    </a>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .hero-zoom {
    animation: kenburns 20s ease-out infinite alternate;
  }
  
  @keyframes kenburns {
    0% { 
      transform: scale(1) translateX(0);
    }
    100% { 
      transform: scale(1.1) translateX(-2%);
    }
  }
  
  .hero-bg.opacity-0 .hero-zoom {
    animation: none;
  }
  
  .hero-bg.opacity-100 .hero-zoom {
    animation: kenburns 20s ease-out infinite alternate;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('previewCarousel');
    const heroBgs = document.querySelectorAll('.hero-bg');
    let currentIndex = 0;
    const total = 4;
    let autoRotateInterval: ReturnType<typeof setInterval>;
    
    function updateCarousel(index: number) {
      currentIndex = index;
      carousel!.style.transform = `translateX(-${index * 100}%)`;
      
      heroBgs.forEach((bg, i) => {
        if (i === index) {
          bg.classList.remove('opacity-0');
          bg.classList.add('opacity-100');
        } else {
          bg.classList.remove('opacity-100');
          bg.classList.add('opacity-0');
        }
      });
    }
    
    function nextSlide() {
      updateCarousel((currentIndex + 1) % total);
    }
    
    function startAutoRotate() {
      autoRotateInterval = setInterval(nextSlide, 5000);
    }
    
    function stopAutoRotate() {
      clearInterval(autoRotateInterval);
    }
    
    startAutoRotate();
    
    document.getElementById('projectPreview')?.addEventListener('mouseenter', stopAutoRotate);
    document.getElementById('projectPreview')?.addEventListener('mouseleave', startAutoRotate);
    document.getElementById('projectPreview')?.addEventListener('click', nextSlide);
  });
</script>
