---
// Hero section - Shed-style: bright images, subtle motion, clean layout
const projectPreviews = [
  { thumb: '/images/portfolio-1.png', hero: '/images/accent-architecture.png' },
  { thumb: '/images/portfolio-2.png', hero: '/images/portfolio-5.png' },
  { thumb: '/images/portfolio-3.png', hero: '/images/portfolio-3.png' },
  { thumb: '/images/portfolio-4.png', hero: '/images/accent-craft.png' },
]
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Marquee strip at top -->
  <div class="absolute top-0 left-0 right-0 z-30 bg-charcoal/30 backdrop-blur-sm py-3 overflow-hidden">
    <div class="marquee-track flex whitespace-nowrap">
      <span class="marquee-content text-white/70 text-sm tracking-wider">
        REMODEL • RENOVATE • REPAIR • THIRD GENERATION CRAFTSMEN • SERVING CHICAGOLAND SINCE 1978 • REMODEL • RENOVATE • REPAIR • THIRD GENERATION CRAFTSMEN • SERVING CHICAGOLAND SINCE 1978 • 
      </span>
      <span class="marquee-content text-white/70 text-sm tracking-wider">
        REMODEL • RENOVATE • REPAIR • THIRD GENERATION CRAFTSMEN • SERVING CHICAGOLAND SINCE 1978 • REMODEL • RENOVATE • REPAIR • THIRD GENERATION CRAFTSMEN • SERVING CHICAGOLAND SINCE 1978 • 
      </span>
    </div>
  </div>

  <!-- Background Images - BRIGHTER with ken burns zoom -->
  <div class="absolute inset-0 z-0">
    {projectPreviews.map((project, index) => (
      <div 
        class={`hero-bg absolute inset-0 transition-opacity duration-1000 ease-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-bg-index={index}
      >
        <img 
          src={project.hero} 
          alt={`Project ${index + 1}`}
          class="w-full h-full object-cover hero-zoom"
        />
      </div>
    ))}
    <!-- LIGHTER overlay - lets more image through -->
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/60 via-charcoal/30 to-transparent z-10"></div>
  </div>
  
  <!-- Content - large bold headline -->
  <div class="relative z-20 w-full px-6 md:px-12 lg:px-24">
    <div class="max-w-full">
      <h1 class="text-[15vw] md:text-[12vw] lg:text-[10vw] font-bold text-white leading-[0.85] tracking-tight">
        <span class="block reveal-up" style="transition-delay: 0.1s">BUILD</span>
        <span class="block reveal-up" style="transition-delay: 0.2s">WHAT</span>
        <span class="block text-gold reveal-up" style="transition-delay: 0.3s">MATTERS</span>
      </h1>
    </div>
  </div>
  
  <!-- Project preview oval (bottom left) -->
  <div class="absolute bottom-8 left-6 md:left-12 lg:left-24 z-20 reveal" style="transition-delay: 1s">
    <div class="project-preview-pill group cursor-pointer" id="projectPreview">
      <div class="relative w-[140px] h-[80px] md:w-[200px] md:h-[110px] rounded-full overflow-hidden border-2 border-white/40 hover:border-gold hover:scale-105 transition-all duration-300 shadow-2xl">
        <div class="preview-carousel absolute inset-0 flex transition-transform duration-500" id="previewCarousel">
          {projectPreviews.map((project, index) => (
            <img 
              src={project.thumb} 
              alt={`Project ${index + 1}`}
              class="w-full h-full object-cover flex-shrink-0"
            />
          ))}
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll button (bottom right) - simplified like Shed -->
  <div class="absolute bottom-8 right-6 md:right-12 lg:right-24 z-20 reveal" style="transition-delay: 1.2s">
    <a href="#services" class="group cursor-pointer">
      <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-white flex items-center justify-center shadow-2xl group-hover:scale-110 group-hover:bg-gold transition-all duration-300">
        <span class="text-charcoal text-xs font-bold tracking-wider group-hover:text-white transition-colors">SCROLL</span>
      </div>
    </a>
  </div>
</section>

<style>
  /* Marquee animation */
  .marquee-track {
    animation: marquee 30s linear infinite;
  }
  
  .marquee-content {
    padding-right: 2rem;
  }
  
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  /* Ken Burns zoom effect on hero images */
  .hero-zoom {
    animation: kenburns 20s ease-out infinite alternate;
  }
  
  @keyframes kenburns {
    0% { 
      transform: scale(1) translateX(0);
    }
    100% { 
      transform: scale(1.1) translateX(-2%);
    }
  }
  
  /* Reset animation when switching images */
  .hero-bg.opacity-0 .hero-zoom {
    animation: none;
  }
  
  .hero-bg.opacity-100 .hero-zoom {
    animation: kenburns 20s ease-out infinite alternate;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('previewCarousel');
    const heroBgs = document.querySelectorAll('.hero-bg');
    let currentIndex = 0;
    const total = 4;
    let autoRotateInterval: ReturnType<typeof setInterval>;
    
    function updateCarousel(index: number) {
      currentIndex = index;
      carousel!.style.transform = `translateX(-${index * 100}%)`;
      
      heroBgs.forEach((bg, i) => {
        if (i === index) {
          bg.classList.remove('opacity-0');
          bg.classList.add('opacity-100');
        } else {
          bg.classList.remove('opacity-100');
          bg.classList.add('opacity-0');
        }
      });
    }
    
    function nextSlide() {
      updateCarousel((currentIndex + 1) % total);
    }
    
    function startAutoRotate() {
      autoRotateInterval = setInterval(nextSlide, 5000);
    }
    
    function stopAutoRotate() {
      clearInterval(autoRotateInterval);
    }
    
    startAutoRotate();
    
    document.getElementById('projectPreview')?.addEventListener('mouseenter', stopAutoRotate);
    document.getElementById('projectPreview')?.addEventListener('mouseleave', startAutoRotate);
    document.getElementById('projectPreview')?.addEventListener('click', nextSlide);
  });
</script>
