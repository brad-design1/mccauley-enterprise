---
// Hero section - full bleed with Shed-inspired touches
const projectPreviews = [
  '/images/portfolio-1.png',
  '/images/portfolio-2.png',
  '/images/portfolio-3.png',
  '/images/portfolio-4.png',
]
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Image - FULL BLEED with parallax -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/accent-architecture.png" 
      alt="McCauley Enterprise construction" 
      class="w-full h-full object-cover parallax-slow scale-110"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/95 via-charcoal/70 to-charcoal/30"></div>
  </div>
  
  <!-- Content -->
  <div class="relative z-10 w-full px-6 md:px-12 lg:px-24 pt-32">
    <div class="max-w-4xl">
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-bold text-white leading-none mb-8">
        <span class="block reveal-up" style="transition-delay: 0.1s">Build</span>
        <span class="block reveal-up" style="transition-delay: 0.2s">What</span>
        <span class="block text-gold reveal-up" style="transition-delay: 0.3s">Matters</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-white/80 mb-10 max-w-xl reveal-up" style="transition-delay: 0.5s">
        Third-generation craftsmen. 45+ years of Chicagoland trust. A clear path to your dream home.
      </p>
      
      <div class="flex flex-wrap gap-4 reveal-up" style="transition-delay: 0.7s">
        <a href="#portfolio" class="btn-primary text-lg magnetic">
          View Our Work
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#contact" class="btn-secondary text-lg border-white text-white hover:bg-white hover:text-charcoal magnetic">
          Start Your Project
        </a>
      </div>
    </div>
  </div>
  
  <!-- SHED-INSPIRED: Project preview oval (bottom left) -->
  <div class="absolute bottom-8 left-6 md:left-12 lg:left-24 z-20 reveal" style="transition-delay: 1s">
    <div class="project-preview-pill group cursor-pointer" id="projectPreview">
      <div class="relative w-[180px] h-[100px] md:w-[220px] md:h-[120px] rounded-full overflow-hidden border-2 border-white/30 hover:border-gold transition-colors duration-300">
        <!-- Image carousel -->
        <div class="preview-carousel absolute inset-0 flex transition-transform duration-500" id="previewCarousel">
          {projectPreviews.map((img, index) => (
            <img 
              src={img} 
              alt={`Project ${index + 1}`}
              class="w-full h-full object-cover flex-shrink-0"
            />
          ))}
        </div>
        <!-- Overlay -->
        <div class="absolute inset-0 bg-charcoal/40 group-hover:bg-charcoal/20 transition-colors flex items-center justify-center">
          <div class="text-center">
            <p class="text-white text-xs font-medium tracking-wider uppercase">View Projects</p>
            <p class="text-gold text-lg font-bold"><span id="previewCount">01</span>/04</p>
          </div>
        </div>
      </div>
      <!-- Nav dots -->
      <div class="flex justify-center gap-2 mt-3">
        {projectPreviews.map((_, index) => (
          <button 
            class={`preview-dot w-2 h-2 rounded-full transition-all ${index === 0 ? 'bg-gold w-4' : 'bg-white/40'}`}
            data-index={index}
          ></button>
        ))}
      </div>
    </div>
  </div>
  
  <!-- SHED-INSPIRED: Scroll circle (bottom right) -->
  <div class="absolute bottom-8 right-6 md:right-12 lg:right-24 z-20 reveal" style="transition-delay: 1.2s">
    <a href="#services" class="scroll-circle group flex flex-col items-center cursor-pointer">
      <div class="relative w-16 h-16 md:w-20 md:h-20 rounded-full border-2 border-white/50 group-hover:border-gold transition-all duration-300 flex items-center justify-center group-hover:scale-110">
        <!-- Rotating text -->
        <svg class="absolute inset-0 w-full h-full animate-spin-slow" viewBox="0 0 100 100">
          <defs>
            <path id="circlePath" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0"/>
          </defs>
          <text class="fill-white/70 text-[11px] tracking-[0.3em] uppercase">
            <textPath href="#circlePath">
              scroll • explore • discover • 
            </textPath>
          </text>
        </svg>
        <!-- Arrow -->
        <svg class="w-5 h-5 text-white group-hover:text-gold transition-colors animate-bounce-slow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </a>
  </div>
</section>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }
  
  .animate-spin-slow {
    animation: spin-slow 15s linear infinite;
  }
  
  .animate-bounce-slow {
    animation: bounce-slow 2s ease-in-out infinite;
  }
</style>

<script>
  // Project preview carousel auto-rotation
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('previewCarousel');
    const countEl = document.getElementById('previewCount');
    const dots = document.querySelectorAll('.preview-dot');
    let currentIndex = 0;
    const total = 4;
    
    function updateCarousel(index) {
      currentIndex = index;
      carousel.style.transform = `translateX(-${index * 100}%)`;
      countEl.textContent = String(index + 1).padStart(2, '0');
      
      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.add('bg-gold', 'w-4');
          dot.classList.remove('bg-white/40');
        } else {
          dot.classList.remove('bg-gold', 'w-4');
          dot.classList.add('bg-white/40');
        }
      });
    }
    
    // Auto-rotate every 3 seconds
    setInterval(() => {
      updateCarousel((currentIndex + 1) % total);
    }, 3000);
    
    // Click dots to navigate
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => updateCarousel(index));
    });
    
    // Click pill to go to portfolio
    document.getElementById('projectPreview')?.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('.preview-dot')) {
        document.getElementById('portfolio')?.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
