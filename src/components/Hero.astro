---
// Hero section - full bleed edge to edge
---

<section class="relative min-h-screen flex items-center">
  <!-- Background Image - FULL BLEED -->
  <div class="absolute inset-0 z-0">
    <div class="w-full h-full bg-gradient-to-br from-navy/90 to-charcoal/80">
      <!-- TODO: Replace with actual hero image -->
      <div class="absolute inset-0 flex items-center justify-center text-white/20 text-sm">
        [HERO IMAGE: Stunning kitchen or living room remodel]
      </div>
    </div>
  </div>
  
  <!-- Content - centered but text can breathe -->
  <div class="relative z-10 w-full px-6 md:px-12 lg:px-24 pt-32">
    <div class="max-w-4xl">
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-bold text-white leading-none mb-8">
        <span class="block">Build</span>
        <span class="block">What</span>
        <span class="block text-gold">Matters</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-white/80 mb-10 max-w-xl">
        Third-generation craftsmen. 45+ years of Chicagoland trust. A clear path to your dream home.
      </p>
      
      <div class="flex flex-wrap gap-4">
        <a href="#portfolio" class="btn-primary text-lg">
          View Our Work
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#contact" class="btn-secondary text-lg border-white text-white hover:bg-white hover:text-charcoal">
          Start Your Project
        </a>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
    <div class="flex flex-col items-center text-white/60">
      <span class="text-sm mb-2">Scroll</span>
      <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>
