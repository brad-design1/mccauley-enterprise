---
// Hero section - clean, minimal with Shed-inspired touches
const projectPreviews = [
  { thumb: '/images/portfolio-1.png', hero: '/images/accent-architecture.png' },
  { thumb: '/images/portfolio-2.png', hero: '/images/portfolio-5.png' },
  { thumb: '/images/portfolio-3.png', hero: '/images/portfolio-3.png' },
  { thumb: '/images/portfolio-4.png', hero: '/images/accent-craft.png' },
]
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Images - stacked for crossfade -->
  <div class="absolute inset-0 z-0">
    {projectPreviews.map((project, index) => (
      <div 
        class={`hero-bg absolute inset-0 transition-opacity duration-700 ease-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-bg-index={index}
      >
        <img 
          src={project.hero} 
          alt={`Project ${index + 1}`}
          class="w-full h-full object-cover scale-110"
        />
      </div>
    ))}
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/95 via-charcoal/70 to-charcoal/30 z-10"></div>
  </div>
  
  <!-- Content - vertically centered -->
  <div class="relative z-10 w-full px-6 md:px-12 lg:px-24">
    <div class="max-w-3xl">
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-bold text-white leading-[0.9] mb-8">
        <span class="block reveal-up" style="transition-delay: 0.1s">Build</span>
        <span class="block reveal-up" style="transition-delay: 0.2s">What</span>
        <span class="block text-gold reveal-up" style="transition-delay: 0.3s">Matters</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-white/80 max-w-md reveal-up" style="transition-delay: 0.5s">
        Third-generation craftsmen.<br/>
        45+ years of Chicagoland trust.
      </p>
    </div>
  </div>
  
  <!-- SHED-INSPIRED: Project preview oval (bottom left) -->
  <div class="absolute bottom-8 left-6 md:left-12 lg:left-24 z-20 reveal" style="transition-delay: 1s">
    <div class="project-preview-pill group cursor-pointer" id="projectPreview">
      <div class="relative w-[140px] h-[80px] md:w-[200px] md:h-[110px] rounded-full overflow-hidden border-2 border-white/30 hover:border-gold hover:scale-105 transition-all duration-300">
        <div class="preview-carousel absolute inset-0 flex transition-transform duration-500" id="previewCarousel">
          {projectPreviews.map((project, index) => (
            <img 
              src={project.thumb} 
              alt={`Project ${index + 1}`}
              class="w-full h-full object-cover flex-shrink-0"
            />
          ))}
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll circle (bottom right) -->
  <div class="absolute bottom-8 right-6 md:right-12 lg:right-24 z-20 reveal" style="transition-delay: 1.2s">
    <a href="#services" class="scroll-circle group flex flex-col items-center cursor-pointer">
      <div class="relative w-14 h-14 md:w-20 md:h-20 rounded-full border-2 border-white/50 group-hover:border-gold transition-all duration-300 flex items-center justify-center group-hover:scale-110">
        <svg class="absolute inset-0 w-full h-full animate-spin-slow" viewBox="0 0 100 100">
          <defs>
            <path id="circlePath" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0"/>
          </defs>
          <text class="fill-white/70 text-[11px] tracking-[0.3em] uppercase">
            <textPath href="#circlePath">
              scroll • explore • discover • 
            </textPath>
          </text>
        </svg>
        <svg class="w-4 h-4 md:w-5 md:h-5 text-white group-hover:text-gold transition-colors animate-bounce-slow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </a>
  </div>
</section>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }
  
  .animate-spin-slow {
    animation: spin-slow 15s linear infinite;
  }
  
  .animate-bounce-slow {
    animation: bounce-slow 2s ease-in-out infinite;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('previewCarousel');
    const heroBgs = document.querySelectorAll('.hero-bg');
    let currentIndex = 0;
    const total = 4;
    let autoRotateInterval: ReturnType<typeof setInterval>;
    
    function updateCarousel(index: number) {
      currentIndex = index;
      carousel!.style.transform = `translateX(-${index * 100}%)`;
      
      heroBgs.forEach((bg, i) => {
        if (i === index) {
          bg.classList.remove('opacity-0');
          bg.classList.add('opacity-100');
        } else {
          bg.classList.remove('opacity-100');
          bg.classList.add('opacity-0');
        }
      });
    }
    
    function nextSlide() {
      updateCarousel((currentIndex + 1) % total);
    }
    
    function startAutoRotate() {
      autoRotateInterval = setInterval(nextSlide, 4000);
    }
    
    function stopAutoRotate() {
      clearInterval(autoRotateInterval);
    }
    
    startAutoRotate();
    
    document.getElementById('projectPreview')?.addEventListener('mouseenter', stopAutoRotate);
    document.getElementById('projectPreview')?.addEventListener('mouseleave', startAutoRotate);
    document.getElementById('projectPreview')?.addEventListener('click', nextSlide);
  });
</script>
