---
// Portfolio grid with staggered reveal and hover effects
const projects = [
  { title: 'Master Bath Renovation', location: 'New Lenox, IL', image: '/images/portfolio-1.png' },
  { title: 'Restaurant Build-Out', location: 'Orland Park, IL', image: '/images/portfolio-2.png' },
  { title: 'Executive Office Suite', location: 'Mokena, IL', image: '/images/portfolio-3.png' },
  { title: 'Modern Retail Storefront', location: 'Frankfort, IL', image: '/images/portfolio-4.png' },
  { title: 'Basement Entertainment', location: 'Homer Glen, IL', image: '/images/portfolio-5.png' },
  { title: 'Historic Restoration', location: 'Tinley Park, IL', image: '/images/portfolio-6.png' },
]
---

<section id="portfolio" class="py-24 md:py-32 bg-charcoal overflow-hidden">
  <div class="w-full px-6 md:px-12 lg:px-24">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <p class="text-gold font-medium mb-4 tracking-wider text-sm uppercase reveal">Portfolio</p>
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white reveal-up" style="transition-delay: 0.1s">
          Our Work
        </h2>
      </div>
      <a href="/projects" class="text-white/80 font-medium hover:text-gold transition-colors flex items-center gap-2 text-lg underline-grow reveal" style="transition-delay: 0.3s">
        View All Projects
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
  
  <!-- Project Grid -->
  <div class="w-full px-6 md:px-12 lg:px-24">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
      {projects.map((project, index) => (
        <div class={`group relative aspect-[4/3] overflow-hidden cursor-pointer reveal-scale stagger-${index + 1}`}>
          <!-- Image with zoom -->
          <img 
            src={project.image} 
            alt={project.title}
            class="absolute inset-0 w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-110 group-hover:brightness-75"
          />
          
          <!-- Default state - subtle gradient -->
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/60 via-transparent to-transparent opacity-60 transition-opacity duration-300 group-hover:opacity-0"></div>
          
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-gold/90 opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-8">
            <h3 class="text-white font-bold text-2xl mb-2 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">{project.title}</h3>
            <p class="text-white/80 translate-y-4 group-hover:translate-y-0 transition-transform duration-300 delay-75">{project.location}</p>
            <div class="mt-4 flex items-center gap-2 text-white font-medium translate-y-4 group-hover:translate-y-0 transition-transform duration-300 delay-150">
              View Project
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
