---
// Portfolio grid - FULL BLEED edge to edge
const projects = [
  { title: 'Kitchen Remodel', location: 'New Lenox, IL', placeholder: 'Modern white kitchen with island' },
  { title: 'Master Bath', location: 'Mokena, IL', placeholder: 'Spa-like bathroom with freestanding tub' },
  { title: 'Whole Home Renovation', location: 'Frankfort, IL', placeholder: 'Open concept living area' },
  { title: 'Commercial Build-Out', location: 'Orland Park, IL', placeholder: 'Restaurant interior' },
  { title: 'Basement Finish', location: 'Homer Glen, IL', placeholder: 'Entertainment space with bar' },
  { title: 'Addition', location: 'Tinley Park, IL', placeholder: 'Family room extension' },
]
---

<section id="portfolio" class="py-24 md:py-32 bg-charcoal">
  <div class="w-full px-6 md:px-12 lg:px-24">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <p class="text-gold font-medium mb-4 tracking-wider text-sm uppercase">Portfolio</p>
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white">
          Our Work
        </h2>
      </div>
      <a href="/projects" class="text-white/80 font-medium hover:text-gold transition-colors flex items-center gap-2 text-lg">
        View All Projects
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
  
  <!-- Project Grid - FULL BLEED -->
  <div class="w-full px-6 md:px-12 lg:px-24">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
      {projects.map(project => (
        <div class="group relative aspect-[4/3] bg-navy overflow-hidden cursor-pointer">
          <!-- Placeholder for image -->
          <div class="absolute inset-0 flex items-center justify-center text-white/30 text-xs p-4 text-center bg-gradient-to-br from-navy to-charcoal">
            [IMAGE: {project.placeholder}]
          </div>
          
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-gold/90 opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col justify-end p-8">
            <h3 class="text-white font-bold text-2xl mb-2">{project.title}</h3>
            <p class="text-white/80">{project.location}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
