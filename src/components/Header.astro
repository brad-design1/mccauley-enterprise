---
const navItems = [
  { label: 'Services', href: '#services' },
  { label: 'Our Work', href: '#portfolio' },
  { label: 'Process', href: '#process' },
  { label: 'About', href: '#about' },
]
---

<header class="fixed top-0 left-0 right-0 z-50 bg-transparent">
  <div class="w-full px-6 md:px-12 lg:px-24">
    <nav class="flex items-center justify-between h-24">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <div class="w-12 h-12 bg-gold rounded flex items-center justify-center">
          <span class="text-white font-bold text-xl">M</span>
        </div>
        <div class="hidden sm:block">
          <span class="font-semibold text-white text-lg">McCauley Enterprise</span>
        </div>
      </a>
      
      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-10">
        {navItems.map(item => (
          <a href={item.href} class="text-white/80 hover:text-white transition-colors font-medium">
            {item.label}
          </a>
        ))}
      </div>
      
      <!-- CTA -->
      <div class="flex items-center gap-6">
        <a href="tel:8155851573" class="hidden lg:block text-white/80 hover:text-white transition-colors">
          (815) 585-1573
        </a>
        <a href="#contact" class="bg-gold hover:bg-gold-dark text-white font-medium py-3 px-6 rounded transition-all hover:-translate-y-0.5">
          Start Your Project
        </a>
      </div>
      
      <!-- Mobile Menu Button -->
      <button class="md:hidden p-2 text-white" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>
</header>
