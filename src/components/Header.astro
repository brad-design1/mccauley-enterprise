---
// Header - minimal with hamburger menu (Shed-style)
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="header">
  <div class="w-full px-6 md:px-12 lg:px-24 py-5 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-white font-bold text-2xl tracking-tight z-[60] relative" id="logo">
      McCauley<span class="text-gold">.</span>
    </a>
    
    <!-- Menu Button -->
    <button 
      class="z-[60] relative flex items-center gap-2 text-white font-medium tracking-wider text-sm group hover:text-gold transition-colors"
      id="menuToggle"
      aria-label="Toggle menu"
    >
      <span class="menu-text transition-all duration-300 group-hover:text-gold" id="menuText">MENU</span>
      <div class="w-8 h-5 flex flex-col justify-between relative">
        <span class="menu-line absolute top-0 w-full h-0.5 bg-white transition-all duration-300 origin-center group-hover:bg-gold" id="line1"></span>
        <span class="menu-line absolute top-1/2 -translate-y-1/2 w-full h-0.5 bg-white transition-all duration-300 origin-center group-hover:bg-gold" id="line2"></span>
        <span class="menu-line absolute bottom-0 w-full h-0.5 bg-white transition-all duration-300 origin-center group-hover:bg-gold" id="line3"></span>
      </div>
    </button>
  </div>
</header>

<!-- Full-screen menu overlay -->
<div 
  class="fixed inset-0 z-[55] bg-gold transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" 
  id="menuOverlay"
  style="transform: translateY(100%);"
>
  <!-- Close button -->
  <button 
    class="absolute top-6 right-6 md:right-12 lg:right-24 z-10 w-12 h-12 flex items-center justify-center text-charcoal hover:text-white transition-colors"
    id="menuClose"
    aria-label="Close menu"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  
  <div class="w-full h-full px-6 md:px-12 lg:px-24 py-24 flex flex-col justify-between overflow-auto">
    <!-- Navigation Links -->
    <nav class="flex-1 flex flex-col justify-center">
      <ul class="space-y-2 md:space-y-4">
        <li>
          <a href="#services" class="nav-link block text-[12vw] md:text-[10vw] lg:text-[8vw] font-bold text-charcoal leading-[0.95] hover:text-navy transition-colors duration-300">
            SERVICES
          </a>
        </li>
        <li>
          <a href="#portfolio" class="nav-link block text-[12vw] md:text-[10vw] lg:text-[8vw] font-bold text-charcoal leading-[0.95] hover:text-navy transition-colors duration-300">
            WORK
          </a>
        </li>
        <li>
          <a href="#about" class="nav-link block text-[12vw] md:text-[10vw] lg:text-[8vw] font-bold text-charcoal leading-[0.95] hover:text-navy transition-colors duration-300">
            ABOUT
          </a>
        </li>
        <li>
          <a href="#contact" class="nav-link block text-[12vw] md:text-[10vw] lg:text-[8vw] font-bold text-charcoal leading-[0.95] hover:text-navy transition-colors duration-300">
            CONTACT
          </a>
        </li>
      </ul>
    </nav>
    
    <!-- Bottom info -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 text-charcoal border-t-2 border-navy pt-8">
      <div>
        <p class="font-bold text-lg text-navy">McCauley Enterprise</p>
        <p class="text-charcoal/70">New Lenox, IL • Chicagoland</p>
      </div>
      <div class="text-right">
        <a href="tel:8155851573" class="text-2xl md:text-3xl font-bold text-navy hover:text-white transition-colors">(815) 585-1573</a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Header scrolled state */
  .header-scrolled {
    background: rgba(26, 26, 26, 0.95);
    backdrop-filter: blur(10px);
  }
  
  /* Nav link animation */
  .nav-link {
    display: inline-block;
    position: relative;
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 4px;
    background: currentColor;
    transition: width 0.3s ease;
  }
  
  .nav-link:hover::after {
    width: 100%;
  }
</style>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const menuClose = document.getElementById('menuClose');
  const menuOverlay = document.getElementById('menuOverlay');
  const menuText = document.getElementById('menuText');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');
  const line3 = document.getElementById('line3');
  const logo = document.getElementById('logo');
  const header = document.getElementById('header');
  const navLinks = document.querySelectorAll('.nav-link');
  
  let menuOpen = false;
  
  function openMenu() {
    menuOpen = true;
    menuOverlay.style.transform = 'translateY(0)';
    document.body.style.overflow = 'hidden';
    
    // Animate hamburger to X
    line1.style.transform = 'rotate(45deg) translateY(10px)';
    line2.style.opacity = '0';
    line3.style.transform = 'rotate(-45deg) translateY(-10px)';
    menuText.style.opacity = '0';
    
    // Change colors for visibility on gold
    logo.classList.remove('text-white');
    logo.classList.add('text-charcoal');
    line1.classList.remove('bg-white');
    line1.classList.add('bg-charcoal');
    line2.classList.remove('bg-white');
    line2.classList.add('bg-charcoal');
    line3.classList.remove('bg-white');
    line3.classList.add('bg-charcoal');
  }
  
  function closeMenu() {
    menuOpen = false;
    menuOverlay.style.transform = 'translateY(100%)';
    document.body.style.overflow = '';
    
    // Animate X back to hamburger
    line1.style.transform = '';
    line2.style.opacity = '1';
    line3.style.transform = '';
    menuText.style.opacity = '1';
    
    // Restore colors
    logo.classList.add('text-white');
    logo.classList.remove('text-charcoal');
    line1.classList.add('bg-white');
    line1.classList.remove('bg-charcoal');
    line2.classList.add('bg-white');
    line2.classList.remove('bg-charcoal');
    line3.classList.add('bg-white');
    line3.classList.remove('bg-charcoal');
  }
  
  // Toggle menu
  menuToggle?.addEventListener('click', () => {
    if (menuOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });
  
  // Close button
  menuClose?.addEventListener('click', () => {
    closeMenu();
  });
  
  // Close menu when clicking a link
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });
  
  // Header scroll state
  function updateHeader() {
    if (window.scrollY > 100 && !menuOpen) {
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
    }
  }
  
  window.addEventListener('scroll', updateHeader);
  updateHeader();
</script>
