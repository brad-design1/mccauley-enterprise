---
// Footer - Shed-style with big CTA
---

<footer class="bg-cream text-charcoal">
  <!-- Big CTA section -->
  <div class="w-full px-6 md:px-12 lg:px-24 py-16 md:py-24 border-b border-charcoal/10">
    <a href="#portfolio" class="group flex items-center justify-between gap-4">
      <div class="flex items-center gap-2 md:gap-4 overflow-hidden">
        <span class="text-[14vw] md:text-[12vw] lg:text-[10vw] font-bold leading-none tracking-tight">SEE</span>
        <span class="text-[14vw] md:text-[12vw] lg:text-[10vw] font-bold leading-none tracking-tight">WORK</span>
        <!-- Embedded image in text - cascading on hover -->
        <div class="hidden md:block w-[15vw] h-[8vw] rounded-lg overflow-hidden relative" id="footerImageContainer">
          <div class="footer-image-slot absolute inset-0" id="footerImageSlot">
            <img src="/images/portfolio-1.png" alt="Project 1" class="absolute inset-0 w-full h-full object-cover" />
            <img src="/images/portfolio-2.png" alt="Project 2" class="absolute inset-0 w-full h-full object-cover" style="transform: translateY(-100%)" />
            <img src="/images/portfolio-3.png" alt="Project 3" class="absolute inset-0 w-full h-full object-cover" style="transform: translateY(-100%)" />
            <img src="/images/portfolio-4.png" alt="Project 4" class="absolute inset-0 w-full h-full object-cover" style="transform: translateY(-100%)" />
            <img src="/images/portfolio-5.png" alt="Project 5" class="absolute inset-0 w-full h-full object-cover" style="transform: translateY(-100%)" />
          </div>
        </div>
      </div>
      
      <!-- Arrow -->
      <div class="flex-shrink-0 w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 flex items-center justify-center group-hover:translate-x-2 transition-transform duration-300">
        <svg class="w-full h-full" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </div>
    </a>
  </div>
  
  <!-- Bottom navigation row - compact inline -->
  <div class="w-full px-6 md:px-12 lg:px-24 py-8">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <!-- Nav links - inline -->
      <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs font-medium tracking-wider">
        <a href="#about" class="hover:text-gold transition-colors">ABOUT</a>
        <a href="#services" class="hover:text-gold transition-colors">SERVICES</a>
        <a href="#portfolio" class="hover:text-gold transition-colors">WORK</a>
        <a href="#process" class="hover:text-gold transition-colors">PROCESS</a>
        <a href="#contact" class="hover:text-gold transition-colors">CONTACT</a>
      </nav>
      
      <!-- Social + contact -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs font-medium tracking-wider">
        <a href="https://www.facebook.com/mccauleyenterprise" target="_blank" class="hover:text-gold transition-colors">FACEBOOK</a>
        <a href="https://www.instagram.com/mccauleyenterprise" target="_blank" class="hover:text-gold transition-colors">INSTAGRAM</a>
        <a href="tel:8155851573" class="hover:text-gold transition-colors">(815) 585-1573</a>
        <span class="text-charcoal/50">SITE BY <a href="https://agentic.so" target="_blank" class="hover:text-gold transition-colors">AGE</a></span>
      </div>
    </div>
  </div>
</footer>

<script>
  const container = document.getElementById('footerImageContainer');
  const slot = document.getElementById('footerImageSlot');
  const images = slot?.querySelectorAll('img');
  
  let isHovering = false;
  let currentIndex = 0;
  let intervalId: ReturnType<typeof setInterval> | null = null;
  let currentDelay = 600; // Start slower
  const minDelay = 100; // Fastest speed
  const acceleration = 0.85; // Speed multiplier each cycle
  
  function dropNextImage() {
    if (!images || !isHovering) return;
    
    const currentImg = images[currentIndex];
    const nextIndex = (currentIndex + 1) % images.length;
    const nextImg = images[nextIndex];
    
    // Current image falls down and out
    currentImg.style.transition = `transform ${currentDelay}ms cubic-bezier(0.4, 0, 1, 1)`;
    currentImg.style.transform = 'translateY(100%)';
    
    // Next image falls in from top
    nextImg.style.transition = 'none';
    nextImg.style.transform = 'translateY(-100%)';
    
    // Force reflow
    nextImg.offsetHeight;
    
    nextImg.style.transition = `transform ${currentDelay}ms cubic-bezier(0.4, 0, 1, 1)`;
    nextImg.style.transform = 'translateY(0)';
    
    currentIndex = nextIndex;
    
    // Accelerate
    currentDelay = Math.max(minDelay, currentDelay * acceleration);
    
    // Schedule next drop
    if (isHovering) {
      intervalId = setTimeout(dropNextImage, currentDelay);
    }
  }
  
  function resetImages() {
    if (!images) return;
    
    images.forEach((img, i) => {
      img.style.transition = 'transform 0.3s ease-out';
      if (i === 0) {
        img.style.transform = 'translateY(0)';
      } else {
        img.style.transform = 'translateY(-100%)';
      }
    });
    
    currentIndex = 0;
    currentDelay = 600;
  }
  
  container?.addEventListener('mouseenter', () => {
    isHovering = true;
    dropNextImage();
  });
  
  container?.addEventListener('mouseleave', () => {
    isHovering = false;
    if (intervalId) {
      clearTimeout(intervalId);
      intervalId = null;
    }
    resetImages();
  });
</script>
