---
// Footer - FULL WIDTH
const currentYear = new Date().getFullYear()
---

<footer class="bg-charcoal text-white">
  <!-- Main footer -->
  <div class="w-full px-6 md:px-12 lg:px-24 py-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-14 h-14 bg-gold rounded flex items-center justify-center">
            <span class="text-white font-bold text-2xl">M</span>
          </div>
          <span class="font-bold text-2xl">McCauley Enterprise</span>
        </div>
        <p class="text-white/50 max-w-md leading-relaxed mb-8 text-lg">
          Third-generation craftsmen building what matters for Chicagoland families since 1978.
        </p>
        <p class="text-3xl font-bold text-gold">REMODEL | RENOVATE | REPAIR</p>
      </div>
      
      <!-- Navigation -->
      <div>
        <p class="font-bold mb-6 text-lg">Navigation</p>
        <ul class="space-y-4 text-white/50">
          <li><a href="#services" class="hover:text-gold transition-colors">Services</a></li>
          <li><a href="#portfolio" class="hover:text-gold transition-colors">Our Work</a></li>
          <li><a href="#process" class="hover:text-gold transition-colors">Process</a></li>
          <li><a href="#about" class="hover:text-gold transition-colors">About</a></li>
          <li><a href="#contact" class="hover:text-gold transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <!-- Contact Info -->
      <div>
        <p class="font-bold mb-6 text-lg">Contact</p>
        <ul class="space-y-4 text-white/50">
          <li>
            <a href="tel:8155851573" class="hover:text-gold transition-colors text-lg">(815) 585-1573</a>
          </li>
          <li>New Lenox, IL</li>
          <li>Greater Chicagoland Area</li>
        </ul>
        
        <!-- Social Links -->
        <div class="flex gap-4 mt-8">
          <a href="#" class="w-12 h-12 bg-white/10 rounded flex items-center justify-center hover:bg-gold transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          <a href="#" class="w-12 h-12 bg-white/10 rounded flex items-center justify-center hover:bg-gold transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="w-full px-6 md:px-12 lg:px-24 py-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-white/40">
        © {currentYear} McCauley Enterprise, Inc. All rights reserved.
      </p>
      <div class="flex gap-8 text-white/40">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
