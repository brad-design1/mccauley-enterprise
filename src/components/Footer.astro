---
// Footer - Shed-style with big CTA
---

<footer class="bg-cream text-charcoal">
  <!-- Top navigation row -->
  <div class="w-full px-6 md:px-12 lg:px-24 py-16 border-b border-charcoal/10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-16">
      <!-- Social -->
      <div class="space-y-2">
        <a href="https://www.facebook.com/mccauleyenterprise" target="_blank" class="block text-sm font-medium hover:text-gold transition-colors">FACEBOOK</a>
        <a href="https://www.instagram.com/mccauleyenterprise" target="_blank" class="block text-sm font-medium hover:text-gold transition-colors">INSTAGRAM</a>
      </div>
      
      <!-- Navigation -->
      <div class="space-y-2">
        <a href="#about" class="block text-sm font-medium hover:text-gold transition-colors">ABOUT</a>
        <a href="#services" class="block text-sm font-medium hover:text-gold transition-colors">SERVICES</a>
        <a href="#portfolio" class="block text-sm font-medium hover:text-gold transition-colors">WORK</a>
        <a href="#process" class="block text-sm font-medium hover:text-gold transition-colors">PROCESS</a>
        <a href="#contact" class="block text-sm font-medium hover:text-gold transition-colors">CONTACT</a>
      </div>
      
      <!-- Contact -->
      <div class="space-y-2">
        <a href="tel:8155851573" class="block text-sm font-medium hover:text-gold transition-colors">(815) 585-1573</a>
        <p class="text-sm text-charcoal/60">New Lenox, IL</p>
      </div>
      
      <!-- Credit -->
      <div class="text-right">
        <p class="text-sm text-charcoal/60">SITE BY <a href="https://agentic.so" target="_blank" class="hover:text-gold transition-colors">AGE</a></p>
      </div>
    </div>
  </div>
  
  <!-- Big CTA section -->
  <div class="w-full px-6 md:px-12 lg:px-24 py-12 md:py-20">
    <a href="#portfolio" class="group flex items-center justify-between gap-4">
      <div class="flex items-center gap-2 md:gap-4 overflow-hidden">
        <span class="text-[14vw] md:text-[12vw] lg:text-[10vw] font-bold leading-none tracking-tight">SEE</span>
        <span class="text-[14vw] md:text-[12vw] lg:text-[10vw] font-bold leading-none tracking-tight">WORK</span>
        <!-- Embedded image in text -->
        <div class="hidden md:block w-[15vw] h-[8vw] rounded-lg overflow-hidden">
          <img 
            src="/images/portfolio-1.png" 
            alt="Our work" 
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
          />
        </div>
      </div>
      
      <!-- Arrow -->
      <div class="flex-shrink-0 w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 flex items-center justify-center group-hover:translate-x-2 transition-transform duration-300">
        <svg class="w-full h-full" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </div>
    </a>
  </div>
  
  <!-- Copyright -->
  <div class="w-full px-6 md:px-12 lg:px-24 py-6 border-t border-charcoal/10">
    <p class="text-xs text-charcoal/50">© 2025 McCauley Enterprise. All rights reserved.</p>
  </div>
</footer>
