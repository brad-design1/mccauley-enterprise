---
// Numbered process section - FULL WIDTH layout
const steps = [
  {
    number: '01',
    title: 'Consultation',
    description: "We meet at your home, listen to your vision, and assess what is possible. No pressure — just honest conversation about your goals and budget."
  },
  {
    number: '02', 
    title: 'Design',
    description: "We create detailed plans that bring your vision to life. You will see exactly what we will build before we swing a single hammer."
  },
  {
    number: '03',
    title: 'Build',
    description: "Our craftsmen get to work. We keep you updated every step of the way with a dedicated project manager who answers when you call."
  },
  {
    number: '04',
    title: 'Completion',
    description: "We walk through every detail together. We do not consider it done until you are thrilled with the result."
  }
]
---

<section id="process" class="py-24 md:py-32 bg-navy text-white">
  <div class="w-full px-6 md:px-12 lg:px-24">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left: Header -->
      <div>
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-8">
          Home Building,<br/>
          <span class="text-gold">Rewired.</span>
        </h2>
        <p class="text-xl text-white/70 mb-10 max-w-md">
          A proven process that has delivered hundreds of successful projects since 1978.
        </p>
        <a href="#contact" class="btn-primary text-lg">
          Start Your Project
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      
      <!-- Right: Steps -->
      <div>
        <p class="text-white/50 text-sm font-medium mb-8 tracking-widest uppercase">Our Process</p>
        <div class="space-y-10">
          {steps.map(step => (
            <div class="flex gap-8 group cursor-pointer">
              <span class="text-gold font-bold text-2xl">{step.number}</span>
              <div class="flex-1 border-b border-white/20 pb-8">
                <h3 class="font-bold text-2xl mb-3 group-hover:text-gold transition-colors">
                  {step.title}
                </h3>
                <p class="text-white/60 leading-relaxed text-lg">
                  {step.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
